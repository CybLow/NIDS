# Conan 2 profile: Linux GCC 13 compatibility mode
#
# Used for local development on Fedora/Ubuntu/Debian.
# Sets compiler.version=13 for Conan binary cache compatibility
# regardless of actual GCC version (GCC ABI is forward-compatible).
#
# Usage:
#   conan install . -pr:h conan/profiles/linux-gcc13 -s build_type=Debug --build=missing

[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=13
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
