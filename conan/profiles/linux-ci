# Conan 2 profile: Linux CI (Ubuntu 24.04, GCC 14)
#
# Used by GitHub Actions CI pipeline. Ubuntu 24.04 provides GCC 14
# as `gcc-14` / `g++-14` packages for C++23 support.
#
# Usage (CI):
#   conan install . -pr:h conan/profiles/linux-ci -s build_type=Release --build=missing

[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=14
compiler.libcxx=libstdc++11
compiler.cppstd=23
build_type=Release

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
