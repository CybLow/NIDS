{
  "name": "NIDS Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "postCreateCommand": "scripts/dev/setup-dev.sh --no-install",
  "remoteUser": "dev",
  "remoteEnv": {
    "CC": "gcc-14",
    "CXX": "g++-14"
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "jetbrains": {
      "backend": "CLion"
    }
  }
}
