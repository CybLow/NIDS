{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.(cpp|h|hpp)$' | xargs -r clang-format -i"
          }
        ]
      }
    ]
  }
}
