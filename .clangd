# clangd configuration for NIDS
# Points to the Conan-managed Debug build directory where
# compile_commands.json is generated by CMake.

CompileFlags:
  CompilationDatabase: build/Debug/
  Add:
    - -std=c++20
    - -Wall
    - -Wextra
    - -Wpedantic
    - -Wconversion
    - -Wsign-conversion

Diagnostics:
  UnusedIncludes: Strict
