# Test Snort rules for unit testing
# Lines starting with # are comments

alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"Test HTTP GET"; content:"GET"; offset:0; depth:3; sid:1000001; rev:1; classtype:web-application-attack; priority:2;)

alert tcp any any -> any 22 (msg:"Test SSH brute force"; content:"SSH-"; nocase; sid:1000002; rev:1; classtype:attempted-admin; priority:1;)

alert udp any any -> any 53 (msg:"Test DNS tunnel"; content:"|00 01|"; content:"tunnel"; distance:4; within:20; sid:1000003; rev:1; classtype:policy-violation; priority:3;)

alert tcp any any -> any any (msg:"Test PCRE rule"; pcre:"/password\s*=\s*['\"][^'\"]+['\"]/i"; sid:1000004; rev:1; classtype:web-application-attack; priority:2;)

alert tcp any any -> any any (msg:"Test flow rule"; flow:established,to_server; content:"POST"; sid:1000005; rev:1;)

alert tcp any any -> any any (msg:"Test negated content"; content:!"SAFE"; content:"DANGER"; sid:1000006; rev:1;)

alert tcp any any -> any any (msg:"Test hex content"; content:"|DE AD BE EF|"; sid:1000007; rev:1; reference:cve,2024-1234; reference:url,example.com;)

alert tcp any any <> any any (msg:"Test bidirectional"; content:"HELLO"; sid:1000008; rev:1;)

alert tcp any any -> any any (msg:"Test threshold"; content:"LOGIN"; threshold:type limit, track by_src, count 5, seconds 60; sid:1000009; rev:1;)

alert tcp any any -> any any (msg:"Test flowbits"; flow:established; flowbits:set,login_attempt; content:"login"; sid:1000010; rev:1;)
